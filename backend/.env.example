# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/taskify

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# Allowed CORS origin in production (e.g. https://taskify.xyz)
CORS_ORIGIN=http://localhost:3000

# Stacks network: testnet | mainnet (default: testnet)
STACKS_NETWORK=testnet

# Deployer address (used as contract address for read-only calls)
# Testnet default: ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
